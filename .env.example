# Backend API base URL (absolute). Used by next.config.ts / the /api/backend proxy.
NEXT_PUBLIC_MEAL_API_BASE_URL=https://meal.https.gsmsv.site

# NEIS (나이스) open API key for school search. Optional — the API works keyless with
# rate limits. Issue one at https://open.neis.go.kr. Used server-side only (/api/neis).
NEIS_API_KEY=
